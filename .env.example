# Shared across all three patterns. Copy to .env in the package you're running.

# --- LLM provider (optional) ---
# With NO key set, @workshop/agent uses a deterministic MOCK model so the whole
# pipeline runs offline. Set one of these for real reviews.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Force the mock client even if a key is present (handy for demos):
# AGENT_MODEL=mock

# --- Postgres (naive-agent & worker-agents) ---
DATABASE_URL=postgres://localhost:5432/agents_workshop

# --- Valkey / Redis (worker-agents only) ---
REDIS_URL=redis://127.0.0.1:6379

# --- HTTP ---
PORT=3000

# --- GitHub (optional) ---
# Public repos work with no token. A token raises rate limits / allows private PRs.
GITHUB_TOKEN=
